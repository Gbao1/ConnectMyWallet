# React app (src/) — copy to web/.env
# Only REACT_APP_* variables are exposed to the browser. Do not put secrets here.

# Main API (ConnectMyTask backend — same API as mobile)
REACT_APP_API_BASE_URL=http://localhost:4000

# Google OAuth (Web client ID — must match GOOGLE_CLIENT_ID on backend)
REACT_APP_GOOGLE_CLIENT_ID=your_google_web_client_id

# Facebook Login (App ID — must match FACEBOOK_APP_ID on backend)
REACT_APP_FACEBOOK_APP_ID=your_facebook_app_id

# Google reCAPTCHA v3 (site key — pair with RECAPTCHA_SECRET_KEY on backend)
REACT_APP_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
REACT_APP_RECAPTCHA_VERIFY_ENABLED=true

# Admin emails allowed to open /admin and /admin/fraud
REACT_APP_ADMIN_EMAILS=admin1@example.com

# Optional Firebase (analytics / future App Check)
# REACT_APP_FIREBASE_API_KEY=
# REACT_APP_FIREBASE_AUTH_DOMAIN=
# REACT_APP_FIREBASE_PROJECT_ID=
# REACT_APP_FIREBASE_STORAGE_BUCKET=
# REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
# REACT_APP_FIREBASE_APP_ID=
# REACT_APP_FIREBASE_MEASUREMENT_ID=

# CRA dev server port (default 3000)
PORT=3000
